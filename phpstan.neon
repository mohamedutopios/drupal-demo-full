includes:
  - vendor/mglaman/phpstan-drupal/extension.neon
  - vendor/phpstan/phpstan-deprecation-rules/rules.neon

parameters:
  level: 6
  paths:
    - web/modules/custom
  excludePaths:
    - web/modules/custom/*/tests
  drupal:
    drupal_root: web
  ignoreErrors:
    # Drupal utilise des méthodes magiques via __call
    - '#Call to an undefined method Drupal\\Core\\Database\\StatementInterface#'
